# Copy to .env (or export) before running the bridge / simulator.

# Backend REST API base. Local standalone server:
BACKEND_BASE_URL=http://localhost:5000
# Or the deployed website (serverless):
# BACKEND_BASE_URL=https://graduation-project-website-phi.vercel.app

# Robot/controller identifier (must exist in the website DB; seeded default below).
ROBOT_IDENTIFIER=RPI-HUB-01

# Bridge polling + timing.
POLL_INTERVAL=2.0
REQUEST_TIMEOUT=10.0

# 'action' -> bridge drives the ExecuteOrder action (default).
# 'topic'  -> bridge relays /robot/task_feedback messages instead.
FEEDBACK_SOURCE=action

# Simulated executor pacing.
SIM_STEP_DELAY=1.5
