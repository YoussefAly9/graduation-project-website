# The API runs as same-origin serverless functions (client/api).
# In production you do NOT need VITE_API_BASE_URL; the app uses /api automatically.

# MongoDB connection string (required for the API to read/write data).
# Set this in the Vercel project (Settings -> Environment Variables) AND in this file for local dev.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/freshmart?retryWrites=true&w=majority

# Local development only: point the frontend at a locally running API.
# VITE_API_BASE_URL=http://localhost:5000/api

# Phone PWA install — use your LAN IP when testing on mobile
# VITE_LAN_ORIGIN=http://192.168.x.x:4173
