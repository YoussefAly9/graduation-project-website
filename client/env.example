# Website on Vercel — use /api (proxied to your server in client/vercel.json)
VITE_API_BASE_URL=/api

# Or call the server directly (no proxy):
# VITE_API_BASE_URL=https://graduation-project-server.vercel.app/api

# Local development
# VITE_API_BASE_URL=http://localhost:5000/api

# Phone PWA install — use your LAN IP when testing on mobile
# VITE_LAN_ORIGIN=http://192.168.x.x:4173
